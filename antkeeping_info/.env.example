DEBUG=True
# ALLOWED_HOSTS=localhost,127.0.0.1
SECRET_KEY=YOUR_SECRET_KEY
# CORS_ORIGIN_WHITELIST=http://localhost:3000
INTERNAL_IPS=127.0.0.1
PUBLIC_ROOT=PATH_TO_PUBLIC_ROOT

# Database
DATABASE_URL=psql://db_user:db_user_pw@127.0.0.1:5432/db_name

# Cache
# When DEBUG=True, dummycache is used automatically (no Redis needed).
# Set CACHE_URL to override, e.g. to test Redis locally.
# CACHE_URL=redis://127.0.0.1:6379

# Email
# Development: use a local SMTP sink (e.g. Mailpit on port 1025)
EMAIL_URL=smtp://localhost:1025
# Production example with STARTTLS:
# EMAIL_URL=smtp+tls://username:password@smtp.example.com:587
DEFAULT_FROM_EMAIL=noreply@example.com
CONTACT_RECIPIENT_EMAIL=admin@example.com

LOGGING_FILENAME=PATH_TO_LOG_FILE